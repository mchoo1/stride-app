rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuth()        { return request.auth != null; }
    function isOwner(uid)    { return request.auth.uid == uid; }
    function isVerifiedPro() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerifiedPro == true;
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      // Subcollections — private to owner
      match /foodLogs/{docId}       { allow read, write: if isOwner(uid); }
      match /activityLogs/{docId}   { allow read, write: if isOwner(uid); }
      match /waterLogs/{docId}      { allow read, write: if isOwner(uid); }
      match /weightLogs/{docId}     { allow read, write: if isOwner(uid); }
      match /workoutLogs/{docId}    { allow read, write: if isOwner(uid); }
      match /dailySummaries/{docId} { allow read, write: if isOwner(uid); }
      match /recommendations/{docId}{ allow read, write: if isOwner(uid); }
      match /notifications/{docId}  { allow read, write: if isOwner(uid); }
      match /wearables/{docId}      { allow read, write: if isOwner(uid); }

      // Follow graph — readable by anyone auth'd
      match /follows/{followingId} {
        allow read:  if isAuth();
        allow write: if isOwner(uid);
      }
      match /followers/{followerId} {
        allow read:  if isAuth();
        allow write: if isAuth();
      }
    }

    // ── Profiles ──────────────────────────────────────────────
    match /profiles/{uid} {
      allow read:   if isAuth();
      allow write:  if isOwner(uid);
    }

    // ── Foods database (legacy) — read by all, write by authenticated ──
    match /foods/{foodId} {
      allow read:   if true;
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.submittedBy == request.auth.uid || isVerifiedPro()
      );
      allow delete: if false;
    }

    // ── Restaurants — public read, no direct client writes ────────────────
    // Populated exclusively by the seed script (server-side admin SDK).
    match /restaurants/{restaurantId} {
      allow read:   if true;
      allow write:  if false;   // admin/seed script only
    }

    // ── Meals — public read, no direct client writes ───────────────────────
    // Populated exclusively by the seed script.
    // meal_feedback writes are handled via /api/meal-feedback route.
    match /meals/{mealId} {
      allow read:   if true;
      allow write:  if false;   // admin/seed script only
    }

    // ── Meal feedback — authenticated create only ──────────────────────────
    // Users can submit feedback. Updates (moderation) are server-side only.
    match /meal_feedback/{feedbackId} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if false;   // server-side moderation only
      allow delete: if false;
    }

    // ── Meal community stats — public read, server-side write only ─────────
    // Updated by Cloud Function when feedback is approved.
    // Read publicly so any user (including unauthenticated) can see community ratings.
    match /meal_community_stats/{mealId} {
      allow read:   if true;
      allow write:  if false;   // Cloud Function / admin SDK only
    }

    // ── Community posts ───────────────────────────────────────
    match /communityPosts/{postId} {
      allow read:   if resource.data.isVisible == true;
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read:   if true;
        allow create: if isAuth();
        allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      }
      match /likes/{userId} {
        allow read:   if true;
        allow write:  if isOwner(userId);
      }
      match /saves/{userId} {
        allow read:   if isOwner(userId);
        allow write:  if isOwner(userId);
      }
    }

    // ── Workout plans ─────────────────────────────────────────
    match /workoutPlans/{planId} {
      allow read:   if resource.data.isPublic == true || (
        isAuth() && resource.data.creatorId == request.auth.uid
      );
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.creatorId == request.auth.uid;
    }

    // ── Providers ─────────────────────────────────────────────
    match /providers/{providerId} {
      allow read:   if resource.data.isActive == true;
      allow create: if isVerifiedPro();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;

      match /menuItems/{itemId} {
        allow read:  if true;
        allow write: if isAuth() &&
          get(/databases/$(database)/documents/providers/$(providerId)).data.userId == request.auth.uid;
      }
      match /classes/{classId} {
        allow read:  if true;
        allow write: if isAuth() &&
          get(/databases/$(database)/documents/providers/$(providerId)).data.userId == request.auth.uid;
      }
    }

    // ── Bookings ──────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read:   if isAuth() && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/providers/$(resource.data.providerId)).data.userId == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/providers/$(resource.data.providerId)).data.userId == request.auth.uid
      );
      allow delete: if false;
    }

    // ── Macro verifications ───────────────────────────────────
    match /macroVerifications/{verificationId} {
      allow read:   if true;
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
